# Windows User Name and Path
export WINUSERNAME=$(cmd.exe /c '<nul set /p=%UserName%' 2>/dev/null)
export WINUSERPATH="/mnt/c/Users/$WINUSERNAME"

# alias
alias pbcopy='clip.exe' # クリップボードにコピー
alias pbpaste='powershell.exe -command "Get-Clipboard"' # 貼り付け
alias open='explorer.exe'

# WezTerm cwd reporting
precmd() {
  printf "\033]7;file://%s%s\033\\" "$HOSTNAME" "$PWD"  # cwd (WezTerm用)
}
